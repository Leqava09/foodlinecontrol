# ============================================================================
# FoodLineControl Environment Configuration
# ============================================================================
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control!

# ============================================================================
# DJANGO CORE SETTINGS
# ============================================================================

# Secret Key - Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# REQUIRED - Must be unique and kept secret
SECRET_KEY=your-secret-key-here-CHANGE-THIS

# Debug Mode - MUST be False in production
# Development: DEBUG=True
# Production: DEBUG=False
DEBUG=False

# Instance Type
# Options: production, development
INSTANCE=production

# Allowed Hosts - Comma-separated list of domains
# Development: ALLOWED_HOSTS=localhost,127.0.0.1,*.ngrok-free.dev
# Production: ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# SECURITY SETTINGS (Production)
# ============================================================================

# SSL/HTTPS - Set to True if using HTTPS (required for production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# HSTS (HTTP Strict Transport Security)
# Production: 31536000 (1 year), Development: 0
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# CSRF Trusted Origins - Comma-separated list with protocol
# Development: CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# Production: CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ============================================================================
# DATABASE SETTINGS
# ============================================================================

# Database Engine
# SQLite: django.db.backends.sqlite3
# PostgreSQL: django.db.backends.postgresql
# MySQL: django.db.backends.mysql
DATABASE_ENGINE=django.db.backends.sqlite3

# Database Name
# SQLite: filename (e.g., db.sqlite3)
# PostgreSQL/MySQL: database name
DATABASE_NAME=db.sqlite3

# PostgreSQL/MySQL Connection (not needed for SQLite)
# DATABASE_USER=your_db_user
# DATABASE_PASSWORD=your_db_password
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
# 
# Before going live, ensure:
# 1. SECRET_KEY is unique and random
# 2. DEBUG=False
# 3. ALLOWED_HOSTS contains your actual domain(s)
# 4. SECURE_SSL_REDIRECT=True (if using HTTPS)
# 5. SESSION_COOKIE_SECURE=True (if using HTTPS)
# 6. CSRF_COOKIE_SECURE=True (if using HTTPS)
# 7. SECURE_HSTS_SECONDS=31536000 (if using HTTPS)
# 8. CSRF_TRUSTED_ORIGINS contains your domain(s) with https://
# 9. Database is PostgreSQL (not SQLite)
# 10. Strong database password set
# 11. Run: python manage.py collectstatic
# 12. Run: python manage.py migrate
# 13. Create superuser: python manage.py createsuperuser
